# AWSインフラ設定
# このファイルをコピーして .env を作成し、実際の値を入力してください
# cp .env.example .env

# ACM証明書ARN（CloudFrontのHTTPS用、us-east-1リージョン）
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:YOUR_ACCOUNT_ID:certificate/YOUR_CERTIFICATE_ID

# S3バケット名（フロントエンド静的ファイル）
S3_BUCKET_NAME=glean-frontend-YOUR_ACCOUNT_ID

# SAMデプロイ用S3バケット名（Lambda成果物）
SAM_S3_BUCKET=glean-sam-artifacts-YOUR_ACCOUNT_ID

# ドメイン名
DOMAIN_NAME=myglean.jp

# フロントエンドURL（CORSのAllowedOrigin）
ALLOWED_ORIGIN=https://www.myglean.jp
