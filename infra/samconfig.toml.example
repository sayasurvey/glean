version = 0.1

[default]
[default.deploy]
[default.deploy.parameters]
stack_name = "glean"
s3_bucket = "glean-sam-artifacts-YOUR_ACCOUNT_ID"
s3_prefix = "glean"
region = "ap-northeast-1"
confirm_changeset = false
capabilities = "CAPABILITY_IAM"
parameter_overrides = [
  "AllowedOrigin=https://www.myglean.jp"
]

[default.build]
[default.build.parameters]
cached = true
parallel = true

[default.sync]
[default.sync.parameters]
watch = true
